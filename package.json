{
  "name": "@reza/medicine-sdk",
  "version": "1.0.0",
  "description": "Production-ready TypeScript SDK for Medicine API",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "publish:npm": "npm publish --access public"
  },
  "keywords": [
    "sdk",
    "typescript",
    "medicine",
    "api-client"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.8.4"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.0.2",
    "typescript": "^5.6.3"
  }
}
